{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://compositions.takoform.com/schemas/v1alpha1/capsule-composition.json",
  "title": "Capsule Composition Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "components"],
  "properties": {
    "apiVersion": {"const": "compositions.takoform.com/v1alpha1"},
    "kind": {"const": "CapsuleComposition"},
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "title"],
      "properties": {
        "name": {"type": "string", "pattern": "^[a-z][a-z0-9-]{0,62}$"},
        "version": {"type": "string", "pattern": "^(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"},
        "title": {"type": "string", "minLength": 1},
        "description": {"type": "string"}
      }
    },
    "components": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": {"$ref": "#/$defs/component"}
    },
    "connections": {
      "type": "array",
      "items": {"$ref": "#/$defs/connection"}
    }
  },
  "$defs": {
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "source"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]{0,62}$"},
        "title": {"type": "string", "minLength": 1},
        "description": {"type": "string"},
        "source": {
          "type": "object",
          "additionalProperties": false,
          "required": ["url", "ref", "path"],
          "properties": {
            "url": {"type": "string", "format": "uri", "pattern": "^https://"},
            "ref": {"type": "string", "minLength": 1, "maxLength": 128},
            "path": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "endpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["component", "interface"],
      "properties": {
        "component": {"type": "string", "pattern": "^[a-z][a-z0-9-]{0,62}$"},
        "interface": {"type": "string", "pattern": "^[a-z][a-z0-9._-]{0,127}$"}
      }
    },
    "connection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to"],
      "properties": {
        "from": {"$ref": "#/$defs/endpoint"},
        "to": {"$ref": "#/$defs/endpoint"}
      }
    }
  }
}
