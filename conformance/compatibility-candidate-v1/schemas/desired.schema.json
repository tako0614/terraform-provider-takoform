{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forms.takoform.com/conformance/compatibility-candidate-v1/desired.schema.json",
  "title": "Takoform compatibility candidate desired fixtures",
  "type": "object",
  "required": ["format", "classification", "cases"],
  "properties": {
    "format": { "const": "takoform.compatibility-candidate.desired@v1" },
    "classification": { "const": "compatibility-candidate" },
    "cases": { "type": "array", "minItems": 10, "maxItems": 10, "items": { "$ref": "#/$defs/case" } }
  },
  "$defs": {
    "case": {
      "type": "object",
      "required": ["kind", "resourceType", "resource"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "resourceType": { "type": "string", "pattern": "^takoform_[a-z_]+$" },
        "resource": { "$ref": "#/$defs/resource" }
      },
      "additionalProperties": false
    },
    "resourceCore": {
      "type": "object",
      "required": ["apiVersion", "kind", "metadata", "spec"],
      "properties": {
        "apiVersion": { "const": "forms.takoform.com/v1alpha1" },
        "kind": { "type": "string", "minLength": 1 },
        "metadata": {
          "type": "object",
          "required": ["name", "space"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "space": { "type": "string", "minLength": 1 },
            "managedBy": { "const": "opentofu" },
            "resourceVersion": { "type": "string", "pattern": "^[1-9][0-9]*$" }
          },
          "additionalProperties": false
        },
        "spec": { "type": "object" }
      }
    },
    "resource": {
      "$ref": "#/$defs/resourceCore",
      "unevaluatedProperties": false
    }
  },
  "additionalProperties": false
}
