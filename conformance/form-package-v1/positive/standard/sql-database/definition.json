{
  "apiVersion": "forms.takoform.com/v1alpha1",
  "kind": "SQLDatabase",
  "definitionVersion": "1.0.0",
  "title": "SQL Database",
  "description": "Provider-neutral SQL storage with an open engine capability token.",
  "status": "standard",
  "desiredSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "additionalProperties": false,
    "properties": {
      "engine": {
        "default": "sqlite",
        "pattern": "^[A-Za-z][A-Za-z0-9._:-]{0,127}$",
        "type": "string"
      },
      "migrationsPath": {
        "minLength": 1,
        "type": "string"
      },
      "name": {
        "maxLength": 128,
        "minLength": 1,
        "pattern": ".*\\S.*",
        "type": "string"
      }
    },
    "required": [
      "name"
    ],
    "type": "object"
  },
  "observedSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "additionalProperties": false,
    "properties": {
      "driftedFields": {
        "items": {
          "pattern": "^(?:/(?:[^~/]|~0|~1)*)+$",
          "type": "string"
        },
        "type": "array",
        "uniqueItems": true
      },
      "generation": {
        "minimum": 1,
        "type": "integer"
      },
      "id": {
        "minLength": 1,
        "type": "string"
      },
      "imported": {
        "type": "boolean"
      },
      "portability": {
        "pattern": "^[A-Za-z][A-Za-z0-9._:-]{0,127}$",
        "type": "string"
      },
      "ready": {
        "type": "boolean"
      }
    },
    "required": [
      "id",
      "ready",
      "generation",
      "imported",
      "portability",
      "driftedFields"
    ],
    "type": "object"
  },
  "outputSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "additionalProperties": false,
    "properties": {
      "generation": {
        "minimum": 1,
        "type": "integer"
      },
      "id": {
        "minLength": 1,
        "type": "string"
      },
      "kind": {
        "const": "SQLDatabase",
        "type": "string"
      },
      "name": {
        "minLength": 1,
        "type": "string"
      },
      "portability": {
        "pattern": "^[A-Za-z][A-Za-z0-9._:-]{0,127}$",
        "type": "string"
      }
    },
    "required": [
      "id",
      "kind",
      "name",
      "generation",
      "portability"
    ],
    "type": "object"
  },
  "immutableFields": [
    "/name",
    "/engine"
  ],
  "lifecycleCapabilities": [
    "create",
    "read",
    "update",
    "delete",
    "import",
    "observe",
    "refresh",
    "drift"
  ],
  "conformanceFixtures": [
    {
      "name": "canonical",
      "desiredPath": "fixtures/desired.json",
      "observedPath": "fixtures/observed.json",
      "outputPath": "fixtures/output.json"
    }
  ],
  "negativeConformanceFixtures": [
    {
      "name": "reject-invalid-semantics",
      "stage": "desired",
      "inputPath": "fixtures/negative.json",
      "expectedFailure": "schema_validation_failed"
    }
  ]
}
