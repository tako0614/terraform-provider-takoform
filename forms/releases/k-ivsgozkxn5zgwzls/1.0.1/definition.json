{
  "apiVersion": "forms.takoform.com/v1alpha1",
  "kind": "EdgeWorker",
  "definitionVersion": "1.0.1",
  "title": "Edge Worker",
  "description": "Provider-neutral edge application backed by a prebuilt immutable artifact.",
  "status": "standard",
  "desiredSchema": {
    "$defs": {
      "artifactSource": {
        "oneOf": [
          {
            "additionalProperties": false,
            "properties": {
              "artifactPath": {
                "minLength": 1,
                "type": "string"
              }
            },
            "required": [
              "artifactPath"
            ],
            "type": "object"
          },
          {
            "additionalProperties": false,
            "properties": {
              "artifactSha256": {
                "$ref": "#/$defs/sha256"
              },
              "artifactUrl": {
                "format": "uri",
                "pattern": "^https://",
                "type": "string"
              }
            },
            "required": [
              "artifactUrl",
              "artifactSha256"
            ],
            "type": "object"
          },
          {
            "additionalProperties": false,
            "properties": {
              "artifactRef": {
                "minLength": 1,
                "type": "string"
              },
              "artifactSha256": {
                "$ref": "#/$defs/sha256"
              }
            },
            "required": [
              "artifactRef",
              "artifactSha256"
            ],
            "type": "object"
          }
        ]
      },
      "connection": {
        "additionalProperties": false,
        "properties": {
          "permissions": {
            "items": {
              "pattern": "^[A-Za-z][A-Za-z0-9._:-]{0,127}$",
              "type": "string"
            },
            "minItems": 1,
            "type": "array",
            "uniqueItems": true
          },
          "projection": {
            "pattern": "^[A-Za-z][A-Za-z0-9._:-]{0,127}$",
            "type": "string"
          },
          "resource": {
            "pattern": "^\\S+$",
            "type": "string"
          }
        },
        "required": [
          "resource",
          "permissions",
          "projection"
        ],
        "type": "object"
      },
      "connections": {
        "additionalProperties": {
          "$ref": "#/$defs/connection"
        },
        "propertyNames": {
          "pattern": "^[A-Za-z][A-Za-z0-9._-]{0,63}$",
          "type": "string",
          "x-takoform-fieldPolicy": "portable-data-only-v1"
        },
        "type": "object"
      },
      "sha256": {
        "pattern": "^(sha256:)?[A-Fa-f0-9]{64}$",
        "type": "string"
      }
    },
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "additionalProperties": false,
    "properties": {
      "compatibilityDate": {
        "minLength": 1,
        "type": "string"
      },
      "compatibilityFlags": {
        "items": {
          "pattern": "^\\S+$",
          "type": "string"
        },
        "type": "array",
        "uniqueItems": true
      },
      "connections": {
        "$ref": "#/$defs/connections"
      },
      "name": {
        "maxLength": 128,
        "minLength": 1,
        "pattern": ".*\\S.*",
        "type": "string"
      },
      "profiles": {
        "items": {
          "pattern": "^\\S+$",
          "type": "string"
        },
        "type": "array",
        "uniqueItems": true
      },
      "source": {
        "$ref": "#/$defs/artifactSource"
      }
    },
    "required": [
      "name",
      "source"
    ],
    "type": "object"
  },
  "observedSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "additionalProperties": false,
    "properties": {
      "driftedFields": {
        "items": {
          "pattern": "^(?:/(?:[^~/]|~0|~1)*)+$",
          "type": "string"
        },
        "type": "array",
        "uniqueItems": true
      },
      "generation": {
        "minimum": 1,
        "type": "integer"
      },
      "id": {
        "minLength": 1,
        "type": "string"
      },
      "imported": {
        "type": "boolean"
      },
      "portability": {
        "pattern": "^[A-Za-z][A-Za-z0-9._:-]{0,127}$",
        "type": "string"
      },
      "ready": {
        "type": "boolean"
      }
    },
    "required": [
      "id",
      "ready",
      "generation",
      "imported",
      "portability",
      "driftedFields"
    ],
    "type": "object"
  },
  "outputSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "additionalProperties": false,
    "properties": {
      "generation": {
        "minimum": 1,
        "type": "integer"
      },
      "id": {
        "minLength": 1,
        "type": "string"
      },
      "kind": {
        "const": "EdgeWorker",
        "type": "string"
      },
      "name": {
        "minLength": 1,
        "type": "string"
      },
      "portability": {
        "pattern": "^[A-Za-z][A-Za-z0-9._:-]{0,127}$",
        "type": "string"
      }
    },
    "required": [
      "id",
      "kind",
      "name",
      "generation",
      "portability"
    ],
    "type": "object"
  },
  "immutableFields": [
    "/name"
  ],
  "lifecycleCapabilities": [
    "create",
    "read",
    "update",
    "delete",
    "import",
    "observe",
    "refresh",
    "drift"
  ],
  "interfaces": [
    {
      "name": "http.request",
      "version": "1",
      "description": "Portable HTTP request surface exposed by an edge application.",
      "required": true,
      "document": {
        "operations": [
          "request"
        ]
      },
      "documentSchema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "additionalProperties": false,
        "properties": {
          "operations": {
            "items": {
              "enum": [
                "request"
              ],
              "type": "string"
            },
            "maxItems": 1,
            "minItems": 1,
            "type": "array",
            "uniqueItems": true
          }
        },
        "required": [
          "operations"
        ],
        "type": "object"
      },
      "inputs": [
        {
          "name": "resource",
          "source": "output",
          "pointer": "/id"
        },
        {
          "name": "name",
          "source": "output",
          "pointer": "/name"
        }
      ]
    }
  ],
  "conformanceFixtures": [
    {
      "name": "canonical",
      "desiredPath": "fixtures/desired.json",
      "observedPath": "fixtures/observed.json",
      "outputPath": "fixtures/output.json"
    }
  ],
  "negativeConformanceFixtures": [
    {
      "name": "reject-invalid-semantics",
      "stage": "desired",
      "inputPath": "fixtures/negative.json",
      "expectedFailure": "schema_validation_failed"
    }
  ]
}
