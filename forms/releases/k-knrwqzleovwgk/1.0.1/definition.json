{
  "apiVersion": "forms.takoform.com/v1alpha1",
  "kind": "Schedule",
  "definitionVersion": "1.0.1",
  "title": "Schedule",
  "description": "Provider-neutral five-field cron lifecycle with one explicit invokable connection.",
  "status": "standard",
  "desiredSchema": {
    "$defs": {
      "connections": {
        "additionalProperties": {
          "$ref": "#/$defs/scheduleConnection"
        },
        "maxProperties": 1,
        "minProperties": 1,
        "propertyNames": {
          "pattern": "^[A-Za-z][A-Za-z0-9._-]{0,63}$",
          "type": "string",
          "x-takoform-fieldPolicy": "portable-data-only-v1"
        },
        "type": "object"
      },
      "scheduleConnection": {
        "additionalProperties": false,
        "properties": {
          "permissions": {
            "contains": {
              "const": "invoke",
              "type": "string"
            },
            "items": {
              "pattern": "^[A-Za-z][A-Za-z0-9._:-]{0,127}$",
              "type": "string"
            },
            "minItems": 1,
            "type": "array",
            "uniqueItems": true
          },
          "projection": {
            "const": "schedule_trigger",
            "type": "string"
          },
          "resource": {
            "pattern": "^\\S+$",
            "type": "string"
          }
        },
        "required": [
          "resource",
          "permissions",
          "projection"
        ],
        "type": "object"
      }
    },
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "additionalProperties": false,
    "properties": {
      "connections": {
        "$ref": "#/$defs/connections"
      },
      "cron": {
        "pattern": "^[0-9*,-]+(?:/[1-9][0-9]*)? [0-9*,-]+(?:/[1-9][0-9]*)? [0-9*,-]+(?:/[1-9][0-9]*)? [0-9*,-]+(?:/[1-9][0-9]*)? [0-9*,-]+(?:/[1-9][0-9]*)?$",
        "type": "string"
      },
      "name": {
        "maxLength": 128,
        "minLength": 1,
        "pattern": ".*\\S.*",
        "type": "string"
      },
      "timezone": {
        "default": "UTC",
        "pattern": "^[A-Za-z][A-Za-z0-9._:/+-]{0,127}$",
        "type": "string"
      }
    },
    "required": [
      "name",
      "cron",
      "connections"
    ],
    "type": "object"
  },
  "observedSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "additionalProperties": false,
    "properties": {
      "driftedFields": {
        "items": {
          "pattern": "^(?:/(?:[^~/]|~0|~1)*)+$",
          "type": "string"
        },
        "type": "array",
        "uniqueItems": true
      },
      "generation": {
        "minimum": 1,
        "type": "integer"
      },
      "id": {
        "minLength": 1,
        "type": "string"
      },
      "imported": {
        "type": "boolean"
      },
      "portability": {
        "pattern": "^[A-Za-z][A-Za-z0-9._:-]{0,127}$",
        "type": "string"
      },
      "ready": {
        "type": "boolean"
      }
    },
    "required": [
      "id",
      "ready",
      "generation",
      "imported",
      "portability",
      "driftedFields"
    ],
    "type": "object"
  },
  "outputSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "additionalProperties": false,
    "properties": {
      "generation": {
        "minimum": 1,
        "type": "integer"
      },
      "id": {
        "minLength": 1,
        "type": "string"
      },
      "kind": {
        "const": "Schedule",
        "type": "string"
      },
      "name": {
        "minLength": 1,
        "type": "string"
      },
      "portability": {
        "pattern": "^[A-Za-z][A-Za-z0-9._:-]{0,127}$",
        "type": "string"
      }
    },
    "required": [
      "id",
      "kind",
      "name",
      "generation",
      "portability"
    ],
    "type": "object"
  },
  "immutableFields": [
    "/name"
  ],
  "lifecycleCapabilities": [
    "create",
    "read",
    "update",
    "delete",
    "import",
    "observe",
    "refresh",
    "drift"
  ],
  "conformanceFixtures": [
    {
      "name": "canonical",
      "desiredPath": "fixtures/desired.json",
      "observedPath": "fixtures/observed.json",
      "outputPath": "fixtures/output.json"
    }
  ],
  "negativeConformanceFixtures": [
    {
      "name": "reject-invalid-semantics",
      "stage": "desired",
      "inputPath": "fixtures/negative.json",
      "expectedFailure": "schema_validation_failed"
    }
  ]
}
