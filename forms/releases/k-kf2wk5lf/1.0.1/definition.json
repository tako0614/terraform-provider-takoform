{
  "apiVersion": "forms.takoform.com/v1alpha1",
  "kind": "Queue",
  "definitionVersion": "1.0.1",
  "title": "Queue",
  "description": "Provider-neutral asynchronous delivery and event fan-out.",
  "status": "standard",
  "desiredSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "additionalProperties": false,
    "properties": {
      "delivery": {
        "additionalProperties": false,
        "properties": {
          "maxBatchSize": {
            "minimum": 0,
            "type": "integer"
          },
          "maxRetries": {
            "minimum": 0,
            "type": "integer"
          }
        },
        "type": "object"
      },
      "name": {
        "maxLength": 128,
        "minLength": 1,
        "pattern": ".*\\S.*",
        "type": "string"
      }
    },
    "required": [
      "name"
    ],
    "type": "object"
  },
  "observedSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "additionalProperties": false,
    "properties": {
      "driftedFields": {
        "items": {
          "pattern": "^(?:/(?:[^~/]|~0|~1)*)+$",
          "type": "string"
        },
        "type": "array",
        "uniqueItems": true
      },
      "generation": {
        "minimum": 1,
        "type": "integer"
      },
      "id": {
        "minLength": 1,
        "type": "string"
      },
      "imported": {
        "type": "boolean"
      },
      "portability": {
        "pattern": "^[A-Za-z][A-Za-z0-9._:-]{0,127}$",
        "type": "string"
      },
      "ready": {
        "type": "boolean"
      }
    },
    "required": [
      "id",
      "ready",
      "generation",
      "imported",
      "portability",
      "driftedFields"
    ],
    "type": "object"
  },
  "outputSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "additionalProperties": false,
    "properties": {
      "generation": {
        "minimum": 1,
        "type": "integer"
      },
      "id": {
        "minLength": 1,
        "type": "string"
      },
      "kind": {
        "const": "Queue",
        "type": "string"
      },
      "name": {
        "minLength": 1,
        "type": "string"
      },
      "portability": {
        "pattern": "^[A-Za-z][A-Za-z0-9._:-]{0,127}$",
        "type": "string"
      }
    },
    "required": [
      "id",
      "kind",
      "name",
      "generation",
      "portability"
    ],
    "type": "object"
  },
  "immutableFields": [
    "/name"
  ],
  "lifecycleCapabilities": [
    "create",
    "read",
    "update",
    "delete",
    "import",
    "observe",
    "refresh",
    "drift"
  ],
  "interfaces": [
    {
      "name": "queue.messages",
      "version": "1",
      "description": "Portable queue delivery operations.",
      "required": true,
      "document": {
        "operations": [
          "acknowledge",
          "receive",
          "send"
        ]
      },
      "documentSchema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "additionalProperties": false,
        "properties": {
          "operations": {
            "items": {
              "enum": [
                "acknowledge",
                "receive",
                "send"
              ],
              "type": "string"
            },
            "maxItems": 3,
            "minItems": 3,
            "type": "array",
            "uniqueItems": true
          }
        },
        "required": [
          "operations"
        ],
        "type": "object"
      },
      "inputs": [
        {
          "name": "resource",
          "source": "output",
          "pointer": "/id"
        },
        {
          "name": "name",
          "source": "output",
          "pointer": "/name"
        }
      ]
    }
  ],
  "conformanceFixtures": [
    {
      "name": "canonical",
      "desiredPath": "fixtures/desired.json",
      "observedPath": "fixtures/observed.json",
      "outputPath": "fixtures/output.json"
    }
  ],
  "negativeConformanceFixtures": [
    {
      "name": "reject-invalid-semantics",
      "stage": "desired",
      "inputPath": "fixtures/negative.json",
      "expectedFailure": "schema_validation_failed"
    }
  ]
}
